# CommerceFlow Configuration
APP_NAME=CommerceFlow
PRODUCT_TAGLINE=Ecommerce Operations Intelligence
FOUNDER_NAME=Sedin Šehić
FOUNDER_URL=https://github.com/a-sehic-dev
PRODUCT_VERSION=1.0.0
APP_ENV=development
DEBUG=true
# Pre-load Atlas demo on server start (guest portfolio mode)
AUTO_BOOTSTRAP_DEMO=true
WORKSPACE_MODE=demo_workspace
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/commerceflow.db

# Uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50

# Analytics
ANALYTICS_CACHE_TTL_SECONDS=300
LOW_STOCK_THRESHOLD=10
DEAD_MIN_DAYS_SINCE_LAST_SALE=180
DEAD_MAX_VELOCITY_90D=0.05
SLOW_MOVING_MIN_DAYS_SINCE_LAST_SALE=60
SLOW_MOVING_MAX_DAYS_SINCE_LAST_SALE=179
SLOW_MOVING_MAX_VELOCITY_90D=0.15
OVERSTOCK_MIN_DAYS_COVER=90
OVERSTOCK_TARGET_DAYS_COVER=90
LOW_STOCK_MAX_DAYS_COVER=14
MARGIN_WARNING_PCT=15

# AI assistant
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ASSISTANT_SESSION_LIMIT=8
ASSISTANT_IP_LIMIT=30
ASSISTANT_COOLDOWN_SECONDS=2.5
ASSISTANT_ALERT_EMAIL=commerceflow.platform@gmail.com

# Private usage insights (/admin/insights?key=...) — leave empty to disable on production
USAGE_STATS_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Future integrations (placeholders)
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# WOOCOMMERCE_URL=
# WOOCOMMERCE_KEY=
# STRIPE_SECRET_KEY=
